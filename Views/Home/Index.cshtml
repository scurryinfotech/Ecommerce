@{
    ViewData["Title"] = "Ecommerce Home";
}

@{
    ViewData["Title"] = "Ecommerce Home";
}

<!-- Main Container -->
<div class="hero">
    <h1>Step Into Style</h1>
    <p>Discover Our Premium Collection of Ladies Sandals</p>
</div>

<div class="container">
    <div class="filters" id="filters"></div>
    <div class="products-grid" id="productsGrid"></div>
    <nav aria-label="Page navigation example">
        <ul class="pagination justify-content-center  mt-1px"> </ul>
    </nav>
</div>

<div class="cart-sidebar" id="cartSidebar">
    <div class="cart-header">
        <h2>Shopping Cart</h2>
        <button class="close-btn" id="closeCart">✕</button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div class="cart-footer">
        <div class="cart-total">
            <span>Total:</span>
            <span id="cartTotal"></span>
        </div>
        <button class="checkout-btn" onclick="checkout()">Proceed to Checkout</button>
    </div>
</div>




@section Scripts {
    <!-- ✅ Razorpay SDK MUST come BEFORE site.js -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <!-- Your JS file comes AFTER -->
    <script src="~/js/site.js"></script>
}